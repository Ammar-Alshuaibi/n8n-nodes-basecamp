{
  "name": "n8n-nodes-basecamp4api",
  "version": "1.0.0",
  "description": "n8n node for Basecamp 3 API integration",
  "keywords": [
    "n8n",
    "n8n-node",
    "n8n-community-node-package",
    "basecamp",
    "project-management"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ammar-Alshuaibi/n8n-nodes-basecamp4api",
  "author": {
    "name": "Ammar Alshuaibi",
    "email": "ammar@smbdm.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ammar-Alshuaibi/n8n-nodes-basecamp4api.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BasecampApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Basecamp/Basecamp.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "prettier": "^2.0.0",
    "typescript": "~4.9.0"
  },
  "dependencies": {
    "n8n-core": "^0.125.0",
    "n8n-workflow": "^0.107.0"
  }
}